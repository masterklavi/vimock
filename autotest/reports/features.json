    {"area": "matching", "feature": "url_path_query_header_jsonpath_absent_equalToJson", "status": "covered", "test": "TestBlackBoxHTTPAdminAndMatchingFeatureMatrix"},
    {"area": "response", "feature": "status_headers_jsonBody_response_template", "status": "covered", "test": "TestBlackBoxHTTPAdminAndMatchingFeatureMatrix"},
    {"area": "matching", "feature": "priority_urlPattern_urlPathPattern_any_method", "status": "covered", "test": "TestBlackBoxPriorityPathPatternScenariosAndDelays"},
    {"area": "response", "feature": "fixedDelay_chunkedDribbleDelay", "status": "covered", "test": "TestBlackBoxPriorityPathPatternScenariosAndDelays"},
    {"area": "scenarios", "feature": "scenario_state_transition_and_reset", "status": "covered", "test": "TestBlackBoxPriorityPathPatternScenariosAndDelays"},
    {"area": "file_api", "feature": "legacy_login_tus_upload_bodyFileName_binary", "status": "covered", "test": "TestBlackBoxLegacyFileUploadAndBodyFile"},
    {"area": "proxy", "feature": "proxyBaseUrl_proxyUrlPrefixToRemove", "status": "covered", "test": "TestBlackBoxProxyAndRecordingWorkflow"},
    {"area": "recording", "feature": "start_proxy_stop_snapshot_activate_mappings", "status": "covered", "test": "TestBlackBoxProxyAndRecordingWorkflow"},
