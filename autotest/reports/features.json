    "external": "VIMOCK_BASE_URL=http://localhost:8080 go test ./autotest/...",
    "selfStart": "VIMOCK_AUTOTEST_START=1 go test ./autotest/...",
    "binarySelfStart": "VIMOCK_AUTOTEST_START=1 VIMOCK_BINARY=./bin/vimock go test ./autotest/..."
